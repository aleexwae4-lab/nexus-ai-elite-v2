{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the SaaS platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "credits": { "type": "number", "description": "Credits available for generation" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Generation": {
      "title": "Generation",
      "description": "A record of an AI generation (image, video, audio, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "audio", "chat", "analysis"] },
        "prompt": { "type": "string" },
        "resultUrl": { "type": "string" },
        "resultText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "createdAt"]
    },
    "Agent": {
      "title": "Agent",
      "description": "A custom AI agent with a master prompt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "systemInstruction": { "type": "string" },
        "model": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "systemInstruction", "model", "createdAt"]
    },
    "ApiKey": {
      "title": "ApiKey",
      "description": "API keys generated by the user for external access",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "keyHash": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "keyHash", "name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/generations/{generationId}": {
      "schema": { "$ref": "#/entities/Generation" },
      "description": "User generations history"
    },
    "/agents/{agentId}": {
      "schema": { "$ref": "#/entities/Agent" },
      "description": "Custom AI Agents"
    },
    "/apiKeys/{apiKeyId}": {
      "schema": { "$ref": "#/entities/ApiKey" },
      "description": "User API Keys"
    }
  }
}
